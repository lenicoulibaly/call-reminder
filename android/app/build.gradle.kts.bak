plugins {
    id("com.android.application")
    id("kotlin-android")
    // Flutter plugin (toujours en dernier)
    id("dev.flutter.flutter-gradle-plugin")
}

android {
    namespace = "com.callreminder.reminder"
    compileSdk = flutter.compileSdkVersion
    ndkVersion = flutter.ndkVersion

    compileOptions {
        sourceCompatibility = JavaVersion.VERSION_11
        targetCompatibility = JavaVersion.VERSION_11
        isCoreLibraryDesugaringEnabled = true
    }

    kotlinOptions {
        jvmTarget = "11"
    }

    defaultConfig {
        applicationId = "com.callreminder.reminder"

        minSdk = flutter.minSdkVersion   // flutter_contacts et flutter_local_notifications requièrent SDK 21+
        targetSdk = flutter.targetSdkVersion

        versionCode = flutter.versionCode
        versionName = flutter.versionName
    }

    buildTypes {
        release {
            signingConfig = signingConfigs.getByName("debug")
        }
    }
}

flutter {
    source = "../.."
}

// 🔥 OBLIGATOIRE pour le desugaring
dependencies {
    coreLibraryDesugaring("com.android.tools:desugar_jdk_libs:2.0.4")
}

